# LN Agent environment configuration
#
# NOTE: The agent reads os.environ directly — there is no dotenv auto-loading.
# To use this file, source it before running:
#   source .env
# Or export all non-comment lines:
#   export $(grep -v '^#' .env | xargs)
# Or configure env vars in your PM2 ecosystem.config.js.

# Leviathan News API
export LN_API=https://api.leviathannews.xyz/api/v1

# Telegram user-session credentials (get api_id and api_hash from https://my.telegram.org).
# Fixed paths read by ln-agent.py:
#   ~/.claude/telegram-creds.json        {"api_id": ..., "api_hash": "..."}
#   ~/.claude/agent_session.session      dedicated Telethon session file

# Wallet auth — set WALLET_PRIVATE_KEY directly, or point to a key file.
# The key must be a raw hex string (with or without 0x prefix), NOT a JSON wallet file.
# Example: 0xabcdef1234567890... (64 hex chars)
export WALLET_PRIVATE_KEY=
# export WALLET_KEY_FILE=~/.claude/.ln-wallet-key

# Bot HQ Telegram group ID — ground truth for duplicate detection (not the LN API).
# Leave unset to skip Bot HQ duplicate checking.
export BOT_HQ_GROUP_ID=

# Optional: Telegram user ID of the bot that posts approved headlines in Bot HQ.
# When set, the Bot HQ dedup fetch filters to messages from this user only;
# leave unset (or 0) to consider every message in the HQ feed.
# export HEADLINE_BOT_USER_ID=0

# ─── LLM providers ───────────────────────────────────────────────────────────

# Binaries auto-detected if on PATH
# export CLAUDE_BIN=/path/to/claude
# export CODEX_BIN=/path/to/codex
# export CODEX_MODEL=gpt-5.6-sol
# export CODEX_EFFORT=xhigh             # reasoning effort: low | medium | high | xhigh
# export CODEX_CLASSIFY_MODEL=gpt-5.6-terra   # bot classification-tier model
# export OPENCODE_BIN=/path/to/opencode
# export OPENCODE_MODEL=anthropic/claude-sonnet-4-5  # required to enable OpenCode

# Provider priority — comma-separated, first available is primary.
# Available: claude, codex, opencode
# Default: codex,claude,opencode
# Example: use only Codex: PROVIDER_ORDER=codex
# Example: Claude first, Codex fallback: PROVIDER_ORDER=claude,codex
# export PROVIDER_ORDER=codex,claude,opencode

# Seconds to skip Claude after quota/rate-limit error (default: 6 hours)
# export CLAUDE_LIMIT_COOLDOWN=21600

# Bot-side transient breaker reset interval, seconds (quota cooldowns still hold)
# export PROVIDER_BREAKER_RESET_INTERVAL=300

# ─── ln-agent.py — news agent ────────────────────────────────────────────────

# Telegram channels to monitor — MUST be a JSON array, not a plain string.
# Correct:   '["@chan1", "@chan2"]'
# Wrong:     "@chan1, @chan2"
# export CHANNELS='["@examplechannel", "@anotherchannel"]'
# export PRIVATE_CHANNELS='["Invite-Only Channel Name"]'

# Cycle interval in seconds (default: 3600 = 1 hour)
# export CYCLE_INTERVAL=3600
# Watchdog deadline for one full cycle, seconds
# export CYCLE_DEADLINE_SECONDS=3300

# Hours to look back on first run (default: 1)
# export INITIAL_LOOKBACK_HOURS=1

# Bot HQ dedup window (hours) and fetch size
# export HQ_DEDUP_HOURS=168
# export HQ_DEDUP_FETCH_LIMIT=300

# Provenance dedup short-circuit (positive matches trusted, absence falls back to HQ check)
# export ENABLE_PROVENANCE_DEDUP=1
# export PROVENANCE_CHECK_URL=

# Source-domain blocklist: BLOCKED_SOURCE_DOMAINS replaces the built-in list,
# EXTRA_BLOCKED_SOURCE_DOMAINS appends. Comma-separated, suffix-matched on host.
# export BLOCKED_SOURCE_DOMAINS=
# export EXTRA_BLOCKED_SOURCE_DOMAINS=

# Users to always upvote / downvote (comma-separated LN usernames, no @)
# export AUTO_UPVOTE_USERS=
# export AUTO_DOWNVOTE_USERS=

# Live-news WebSocket listener (events queued into ws_events)
# export ENABLE_WS_EVENTS=1
# export WS_NEWS_URL=wss://api.leviathannews.xyz/ws/news/
# export WS_NEWS_ORIGIN=https://leviathannews.xyz
# export WS_PING_INTERVAL=20
# export WS_PING_TIMEOUT=45
# export WS_BACKOFF_BASE=5
# export WS_BACKOFF_CAP=300
# export WS_STABLE_SECONDS=60

# Between-cycle mini-pass over queued WS events (votes/comments only)
# export ENABLE_WS_MINI_PASS=1
# export MINI_PASS_MIN_INTERVAL=600
# export MINI_PASS_DEADLINE=900
# export MINI_PASS_MAX_ARTICLES=5

# Market-match phase (flag-gated, default off)
# export ENABLE_MARKET_MATCH=0
# export MARKET_MATCH_MAX_PER_CYCLE=5
# export MARKET_MATCH_ATTACH_MIN_CONFIDENCE=0.75
# export MARKET_MATCH_MAX_B=1000

# Telegram client — bundled at skills/telegram-explorer/scripts/telegram_client.py
# export TELEGRAM_CLIENT_SCRIPT=skills/telegram-explorer/scripts/telegram_client.py
# export TELEGRAM_CLIENT_PYTHON=.venv/bin/python3

# Twitter/X script — NOT bundled (ToS concerns). Provide your own implementation.
# See README for interface requirements. Agent works without it (no X context).
# export TWITTER_FETCH_SCRIPT=scripts/twitter_fetch.py
# export TWITTER_FETCH_PYTHON=.venv/bin/python3

# ─── Agent identity ──────────────────────────────────────────────────────────

# Agent name — appears in prompts and logs. Name your agent instance.
export AGENT_NAME=Agent

# ─── benthic-bot.py — chat bot ───────────────────────────────────────────────

# Bot token — REQUIRED for benthic-bot.py
# Get from @BotFather on Telegram
export BOT_TOKEN=
# export BOT_TOKEN_FILE=~/.claude/.ln-bot-token

# Bot username (lowercase, no @) — REQUIRED for benthic-bot.py
export BOT_USERNAME=

# Agents group ID — REQUIRED (same as BOT_HQ_GROUP_ID or a different group)
export AGENTS_GROUP_ID=

# Additional groups (JSON array of int chat IDs)
# export ALLOWED_GROUPS='[-100123456789]'

# Operator Telegram user IDs (JSON array) — users who can give the bot commands
# Get your ID from @userinfobot on Telegram
export OPERATOR_IDS='[]'

# Agent directory — controls Bash tool path restrictions for operators
# export AGENT_DIR=/path/to/agent-dir

# Local state overrides (DB + log paths; also used by the test suite)
# export BENTHIC_DB=agent.db
# export BENTHIC_LOG_FILE=benthic.log

# Autonomous trading
# export MARKET_CHECK_INTERVAL=1800
# export MAX_MARKET_BUY_SQUID=500
# export MARKET_CACHE_MAX_AGE=300
# export MARKET_PRICE_DELTA_PCT=15

# Evidence-grounded replies (see CLAUDE.md for semantics; malformed values stop startup)
# export ENABLE_REPLY_GROUNDING=1
# export BENTHIC_ENGAGEMENT_TIMEOUT=120        # clamped to 30..300
# export GROUNDING_MAX_BACKGROUND_SOURCES=3
# export GROUNDING_MAX_FOCAL_URLS=8
# export GROUNDING_MAX_SOURCE_REQUESTS=10
# export GROUNDING_MAX_SOURCE_BYTES=2097152
# export GROUNDING_SOURCE_COLLECTION_TIMEOUT=960
# export GROUNDING_MAX_EVIDENCE_BYTES=24000
# export GROUNDING_FETCH_TIMEOUT=15
# export GROUNDING_TRACE_RETENTION_DAYS=14

# Media grounding
# export PHOTO_REFERENCE_MAX_AGE=1800
# export PHOTO_RETENTION_DAYS=7
# export MAX_ATTACHED_PHOTOS=2

# Breaking-news reactions from the live-news WS queue
# export ENABLE_WS_BREAKING_NEWS=1
# export BREAKING_NEWS_MIN_INTERVAL=3600
# export BREAKING_NEWS_MAX_AGE=900
# export WS_NEWS_CHAT_ID=              # defaults to AGENTS_GROUP_ID

# Tool binary overrides (auto-resolved by default)
# export PM2_BIN=/path/to/pm2
# export GITHUB_CLIENT_BIN=./github_client.sh
# export RUN_SANDBOX_SCRIPT=./sandbox/run-sandbox.sh

# ─── benthic_api.py — news API service ───────────────────────────────────────

# Static bearer token callers must send — REQUIRED to expose the API
# export API_KEY=
# export API_PORT=8099
# export API_DB_PATH=agent.db
# export API_RATE_LIMIT=10             # analyze requests/min

# ─── benthic-builder.py — optional async build daemon ────────────────────────

# GitHub org/user to publish auto-built repos under — REQUIRED to run the builder
# export BUILD_GITHUB_ORG=YourGithubOrg

# git author identity for the initial commit on each built repo
# export BUILD_GIT_USER_NAME="Agent Builder"
# export BUILD_GIT_USER_EMAIL="agent@example.com"

# Optional: override agent base dir, workdir / log paths, timeouts, loop caps
# export BENTHIC_BASE=/path/to/agent-dir
# export BUILD_ROOT=/tmp/benthic-builds
# export BUILD_LOG_ROOT=/tmp/benthic-build-logs
# export BUILD_TIMEOUT=21600        # 6 hours per task (hard cap)
# export BUILD_POLL_INTERVAL=10     # seconds between queue polls
# export BUILD_MAX_TURNS=40         # goal-loop turn cap (app-server mode)
# export BUILD_USE_APPSERVER=1      # 0 = force codex exec fallback
# export LOG_LEVEL=INFO

# ─── github_client.sh ────────────────────────────────────────────────────────

# GitHub org/user for repo create/push allowlisting (falls back to gh login)
# export GITHUB_ORG=
# Non-operator write rate limit per 24h
# export RATE_LIMIT_MAX=30
